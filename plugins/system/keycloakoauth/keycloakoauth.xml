<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_keycloakoauth</name>
    <author>Sebastian Meyer</author>
    <creationDate>2026-03-14</creationDate>
    <copyright>2026 Sebastian Meyer</copyright>
    <license>GNU General Public License v2 or later</license>
    <authorEmail>contact@example.com</authorEmail>
    <authorUrl>https://example.com</authorUrl>
    <version>1.0.0</version>
    <description>PLG_SYSTEM_KEYCLOAKOAUTH_DESC</description>
    <namespace path="src">Joomla\Plugin\System\Keycloakoauth</namespace>
    <files>
        <filename plugin="keycloakoauth">src/Extension/Keycloakoauth.php</filename>
        <file>index.html</file>
        <folder>language</folder>
        <folder>src</folder>
        <folder>services</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/plg_system_keycloakoauth.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_keycloakoauth.sys.ini</language>
    </languages>
    <config>
        <fields name="params" addfieldprefix="Joomla\Plugin\System\Keycloakoauth\Field">
            <fieldset name="oauth" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELDSET_OAUTH">
                <field name="client_id" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_CLIENT_ID" />
                <field name="client_secret" type="password"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_CLIENT_SECRET" />
                <field name="base_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_BASE_URL" />
                <field name="discover_endpoints_button" type="DiscoverEndpointsButton"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_DISCOVER_ENDPOINTS_BUTTON" />
                <field name="auth_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_AUTH_URL" />
                <field name="token_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_TOKEN_URL" />
                <field name="userinfo_url" type="text"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_USERINFO_URL" />
                <field name="redirect_uri" type="text"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_REDIRECT_URI" />
            </fieldset>
            <fieldset name="mapping" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELDSET_MAPPING">
                <field name="username_mapping" type="MappingSelect"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_USERNAME_MAPPING" />
                <field name="email_mapping" type="MappingSelect"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_EMAIL_MAPPING" />
                <field name="try_connection_button" type="TryConnectionButton"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_TRY_CONNECTION_BUTTON" />
            </fieldset>
            <fieldset name="group_mapping" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELDSET_GROUP_MAPPING">
                <field name="remove_all_unmapped_groups" type="PersistedCheckbox"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_REMOVE_ALL_UNMAPPED_GROUPS"
                    description="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_REMOVE_ALL_UNMAPPED_GROUPS_DESC"
                    default="0"
                    value="1" />
                <field name="group_mappings" type="GroupMappings"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_GROUP_MAPPINGS" />
            </fieldset>
            <fieldset name="integration_settings"
                label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELDSET_INTEGRATION_SETTINGS">
                <field name="allow_normal_user_login" type="PersistedCheckbox"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_ALLOW_NORMAL_USER_LOGIN"
                    default="0"
                    value="1" />
                <field name="allow_admin_user_login" type="PersistedCheckbox"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_ALLOW_ADMIN_USER_LOGIN"
                    default="0"
                    value="1" />
                <field name="allow_new_user_creation_on_logon" type="PersistedCheckbox"
                    label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_ALLOW_NEW_USER_CREATION_ON_LOGON"
                    default="0"
                    value="1" />
            </fieldset>
        </fields>
    </config>
</extension>