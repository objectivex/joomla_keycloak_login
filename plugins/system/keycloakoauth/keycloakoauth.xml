<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_keycloakoauth</name>
    <author>Sebastian Meyer</author>
    <creationDate>2026-03-14</creationDate>
    <copyright>2026 Sebastian Meyer</copyright>
    <license>GNU General Public License v2 or later</license>
    <authorEmail>contact@example.com</authorEmail>
    <authorUrl>https://example.com</authorUrl>
    <version>1.0.0</version>
    <description>PLG_SYSTEM_KEYCLOAKOAUTH_DESC</description>
    <namespace path="src">Joomla\Plugin\System\Keycloakoauth</namespace>
    <files>
        <filename plugin="keycloakoauth">src/Extension/Keycloakoauth.php</filename>
        <file>index.html</file>
        <folder>language</folder>
        <folder>src</folder>
        <folder>services</folder>
    </files>
    <languages>
        <language tag="en-GB">language/en-GB/plg_system_keycloakoauth.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_keycloakoauth.sys.ini</language>
    </languages>
    <config>
        <fields name="params">
            <fieldset name="oauth" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELDSET_OAUTH">
                <field name="client_id" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_CLIENT_ID" />
                <field name="client_secret" type="password" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_CLIENT_SECRET" />
                <field name="base_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_BASE_URL" />
                <field name="auth_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_AUTH_URL" />
                <field name="token_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_TOKEN_URL" />
                <field name="userinfo_url" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_USERINFO_URL" />
                <field name="redirect_uri" type="text" label="PLG_SYSTEM_KEYCLOAKOAUTH_FIELD_REDIRECT_URI" />
            </fieldset>
        </fields>
    </config>
</extension>